# ===========================================================================
#   Restaurant Chatbot — Environment Configuration
#  Copy this file to ".env" and fill in your own values.
#  (The ".env" file is private and is never committed to git.)
# ===========================================================================

# --- Groq API (PRIMARY provider) --------------------------------------------
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=

# Primary Groq model (tried first) and secondary Groq model (tried next if the
# primary fails). gpt-oss-120b gives the best Arabic + reliable tool calling.
GROQ_MODEL_1=openai/gpt-oss-120b
GROQ_MODEL_2=qwen/qwen3-32b

# --- Google Gemini API (FALLBACK provider) ----------------------------------
# Used automatically only if every Groq model above fails.
# Get a free key at: https://aistudio.google.com/  (Get API key)
GEMINI_API_KEY=

MODEL_GEMINI_1=gemini-2.5-flash
MODEL_GEMINI_2=gemini-2.0-flash

# --- Google Sheets (reservations storage) -----------------------------------
# Path to the service-account credentials file you downloaded from Google Cloud.
GOOGLE_CREDENTIALS_FILE=credentials.json

# The Sheet ID = the long code in your sheet URL between /d/ and /edit
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=

# The tab (worksheet) name where reservations are saved. Created automatically.
GOOGLE_WORKSHEET_NAME=Reservations
